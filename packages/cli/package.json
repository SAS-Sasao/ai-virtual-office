{
  "name": "ai-office",
  "version": "0.0.0",
  "description": "Claude Code hooks を ai-virtual-office Relay に配線する設定管理 CLI（setup / doctor / teardown）",
  "type": "module",
  "bin": {
    "ai-office": "./dist/index.js"
  },
  "files": [
